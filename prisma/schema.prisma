generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 부고장
model Obituary {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 고인 정보
  deceasedName   String // 고인 성함
  deceasedPhoto  String? // 고인 사진 URL
  birthDate      String? // 생년월일
  deathDate      String  // 사망일

  // 장례 정보
  funeralHall    String  // 장례식장명
  funeralAddress String  // 장례식장 주소
  funeralLat     Float?  // 위도
  funeralLng     Float?  // 경도
  funeralPhone   String? // 장례식장 연락처
  funeralDate    String  // 발인 일시
  burialPlace    String? // 장지

  // 템플릿
  template String @default("classic") // classic, modern, warm, serene

  // 관계
  mourners   Mourner[]
  guestbooks Guestbook[]
  gallery    GalleryImage[]
}

// 상주 (+ 계좌 정보)
model Mourner {
  id        String @id @default(uuid())
  name      String // 상주 이름
  relation  String // 고인과의 관계 (장남, 차남 등)
  phone     String? // 연락처
  bankName  String? // 은행명
  accountNo String? // 계좌번호
  accountHolder String? // 예금주

  obituaryId String
  obituary   Obituary @relation(fields: [obituaryId], references: [id], onDelete: Cascade)
}

// 방명록
model Guestbook {
  id        String   @id @default(uuid())
  author    String   // 작성자
  message   String   // 조문 메시지
  password  String   // 삭제용 비밀번호
  createdAt DateTime @default(now())

  obituaryId String
  obituary   Obituary @relation(fields: [obituaryId], references: [id], onDelete: Cascade)
}

// 추모 갤러리
model GalleryImage {
  id       String @id @default(uuid())
  url      String // 이미지 URL
  caption  String? // 설명
  sortOrder Int @default(0)

  obituaryId String
  obituary   Obituary @relation(fields: [obituaryId], references: [id], onDelete: Cascade)
}
